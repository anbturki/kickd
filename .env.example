# Daemon config
KICKD_PORT=7400

# Auth (optional - if set, all API requests require this token)
KICKD_API_TOKEN=

# Encryption key for credential vault (generate with: openssl rand -base64 32)
KICKD_ENCRYPTION_KEY=

# LinkedIn API credentials (for linkedin skills/tasks)
# Get these from https://developer.linkedin.com/
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_PERSON_URN=urn:li:person:your_person_id
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REFRESH_TOKEN=

# Notification channels (optional - quick setup via env)
KICKD_NOTIFY_SLACK_URL=
KICKD_NOTIFY_DISCORD_URL=
KICKD_NOTIFY_WEBHOOK_URL=
